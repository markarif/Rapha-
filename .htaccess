Options -Indexes

# ── Clean URLs (remove .php) — excludes /admin/ ──────
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Redirect /index.php to /
  RewriteCond %{THE_REQUEST} \s/+index\.php[\s?] [NC]
  RewriteRule ^index\.php$ / [R=301,L]

  # 301 redirect: strip .php from public pages (not admin/)
  RewriteCond %{THE_REQUEST} \s(.+?)\.php[\s?] [NC]
  RewriteCond %{REQUEST_URI} !^/admin/ [NC]
  RewriteRule ^ %1 [R=301,L]

  # Internally rewrite clean public URLs to .php files
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !^/admin/ [NC]
  RewriteRule ^([^/]+)/?$ $1.php [L]
</IfModule>

# ── Compression ──────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain
</IfModule>

# ── Browser caching ──────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png  "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType text/css   "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
</IfModule>
